# --- Python bytecode / cache ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
venv/
env/

# --- Test / coverage ---
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Local test scratch files (not for repo) ---
tests/_local/
tests/local_*.py
tests/test_local_*.py
tests/*_local.py
tests/tmp_*.py

# --- Type checker / linter / tooling caches ---
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/

# --- Build / packaging ---
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Editor / OS files ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Local runtime / debug output ---
*.log
*.tmp
*.bak

# --- Local generated program files (outside source control) ---
*.step.json
*.lse

# --- Repo cleanup scope (user-selected) ---
tests/
ngc/*.ngc
*_REPORT.md
*_SUMMARY.md
IMPLEMENTATION_*.md
COMPLIANCE_*.md
widget_ids.json
