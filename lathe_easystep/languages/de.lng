# --- Ergaenzt: Tooltips fuer Planen/Bohren/Kontur/Keilnut ---
tooltip.face_start_x=Start-Durchmesser (X) des Plandrehzyklus.
tooltip.face_start_z=Start-Z-Position des Plandrehzyklus.
tooltip.face_end_x=End-Durchmesser (X) des Plandrehzyklus.
tooltip.face_end_z=End-Z-Position des Plandrehzyklus.
tooltip.face_mode=Schruppen, Schlichten oder beides in einem Schritt.
tooltip.face_finish_direction=Schlichtrichtung: von aussen nach innen oder von innen nach aussen.
tooltip.face_depth_max=Maximale Zustellung pro Schruppschnitt.
tooltip.face_finish_allow_x=Radialer Schlichtzuschlag, der beim Schruppen stehen bleibt.
tooltip.face_finish_allow_z=Axialer Schlichtzuschlag, der beim Schruppen stehen bleibt.
tooltip.face_edge_type=Kantenbehandlung am Ende der Planflaeche: keine, Fase oder Radius.
tooltip.face_edge_size=Mass der Fase bzw. des Radius an dieser Kante.
tooltip.face_safe_z=Sichere Z-Position zum Anfahren vor dem Zyklus.
tooltip.face_feed=Vorschub beim Plandrehen.
tooltip.face_pause_enabled=Kurze Pause zum Spanbrechen waehrend des Schruppens.
tooltip.face_pause_distance=Zustellweg zwischen zwei Spanbruch-Pausen.
tooltip.face_spindle=Drehzahl bzw. Schnittgeschwindigkeit fuer diesen Schritt.
tooltip.face_tool=Werkzeug fuer das Plandrehen.
tooltip.face_coolant=Kuehlmittel waehrend des Plandrehens einschalten.
tooltip.face_depth_per_pass=Zustellung pro Schnitt beim Plandrehen.
tooltip.drill_tool=Werkzeug fuer den Bohrzyklus.
tooltip.drill_spindle=Drehzahl fuer den Bohrzyklus.
tooltip.drill_coolant=Kuehlmittel waehrend des Bohrens einschalten.
tooltip.drill_mode=Bohrzyklus-Typ: normal, mit Verweilzeit, Tieflochbohren, Spanbrechen oder Gewindebohren.
tooltip.drill_diameter=Bohrungsdurchmesser (nur Referenz fuer die Vorschau).
tooltip.drill_depth=Bohrtiefe in Z.
tooltip.drill_feed=Vorschub beim Bohren.
tooltip.drill_safe_z=Sichere Z-Position zum Anfahren vor dem Zyklus.
tooltip.drill_dwell=Verweilzeit am Bohrungsgrund (nur bei Zyklus mit Verweilzeit).
tooltip.drill_peck_depth=Zustelltiefe pro Hub bei Tieflochbohren bzw. Spanbrechen.
tooltip.contour_start_x=Startdurchmesser (X) der Kontur.
tooltip.contour_start_z=Start-Z-Position der Kontur.
tooltip.contour_coord_mode=Absolute oder inkrementelle Eingabe der Konturpunkte.
tooltip.contour_name=Name der Kontur zur Zuordnung in Abspanen-Schritten.
tooltip.contour_add_segment=Fuegt ein neues Konturelement (Zeile) hinzu.
tooltip.contour_delete_segment=Entfernt das ausgewaehlte Konturelement.
tooltip.contour_move_up=Verschiebt das ausgewaehlte Konturelement nach oben.
tooltip.contour_move_down=Verschiebt das ausgewaehlte Konturelement nach unten.
tooltip.contour_edge_type=Kantenbehandlung am Ende dieses Konturelements: keine, Fase oder Radius.
tooltip.contour_edge_size=Mass der Fase bzw. des Radius an dieser Kante.
tooltip.contour_arc_side=Lage des Kreisbogens bei einem Radius: automatisch, aussen oder innen.
tooltip.key_mode=Nutenstossen axial (Z-Richtung) oder stirnseitig (X-Richtung).
tooltip.key_radial_side=Nut aussen an der Welle oder innen in einer Bohrung.
tooltip.key_tool=Werkzeug fuer das Nutenstossen.
tooltip.key_coolant=Kuehlmittel waehrend des Nutenstossens einschalten.
tooltip.key_slot_count=Anzahl gleichmaessig ueber den Umfang verteilter Nuten.
tooltip.key_slot_start_angle=Winkel der ersten Nut auf der C-Achse.
tooltip.key_slot_angle_step=Winkelversatz zwischen aufeinanderfolgenden Nuten.
tooltip.key_start_diameter=Durchmesser, an dem die Nut beginnt.
tooltip.key_start_z=Z-Position des Nutanfangs.
tooltip.key_nut_length=Laenge der Nut.
tooltip.key_nut_depth=Tiefe der Nut.
tooltip.key_slot_width=Sollbreite der fertigen Nut.
tooltip.key_depth_per_pass=Zustellung pro Schnitt beim Nutenstossen.
tooltip.key_plunge_feed=Vorschub beim Eintauchen bzw. Stossen.
tooltip.key_cutting_width=Schneidenbreite des Werkzeugs; bestimmt die Ueberlappung bei breiteren Nuten.
tooltip.key_top_clearance=Sicherheitsabstand oberhalb der Nut vor dem Eintauchen.
tooltip.key_use_c_axis=C-Achse fuer die Winkelpositionierung der Nuten verwenden.
tooltip.key_use_c_axis_switch=Zwischen den Nuten per M-Code in den C-Achsen-Modus umschalten.
tooltip.key_c_axis_switch_p=P-Parameter des M-Codes zum Umschalten in den C-Achsen-Modus.
