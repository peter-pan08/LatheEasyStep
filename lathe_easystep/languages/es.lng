# --- Ergaenzt: Tooltips fuer Planen/Bohren/Kontur/Keilnut ---
tooltip.face_start_x=Diametro inicial (X) del ciclo de refrentado.
tooltip.face_start_z=Posicion Z inicial del ciclo de refrentado.
tooltip.face_end_x=Diametro final (X) del ciclo de refrentado.
tooltip.face_end_z=Posicion Z final del ciclo de refrentado.
tooltip.face_mode=Desbaste, acabado o ambos en un solo paso.
tooltip.face_finish_direction=Direccion de acabado: de fuera hacia dentro o de dentro hacia fuera.
tooltip.face_depth_max=Profundidad maxima de pasada de desbaste.
tooltip.face_finish_allow_x=Sobremedida radial de acabado que queda tras el desbaste.
tooltip.face_finish_allow_z=Sobremedida axial de acabado que queda tras el desbaste.
tooltip.face_edge_type=Tratamiento de arista al final de la cara: ninguno, chaflan o radio.
tooltip.face_edge_size=Tamano del chaflan o radio en esta arista.
tooltip.face_safe_z=Posicion Z segura para aproximarse antes del ciclo.
tooltip.face_feed=Avance para el refrentado.
tooltip.face_pause_enabled=Pausa breve para rotura de viruta durante el desbaste.
tooltip.face_pause_distance=Recorrido entre dos pausas de rotura de viruta.
tooltip.face_spindle=Velocidad del husillo o velocidad de corte para este paso.
tooltip.face_tool=Herramienta usada para el refrentado.
tooltip.face_coolant=Activar refrigerante durante el refrentado.
tooltip.face_depth_per_pass=Profundidad de pasada durante el refrentado.
tooltip.drill_tool=Herramienta para el ciclo de taladrado.
tooltip.drill_spindle=Velocidad del husillo para el ciclo de taladrado.
tooltip.drill_coolant=Activar refrigerante durante el taladrado.
tooltip.drill_mode=Tipo de ciclo de taladrado: normal, con tiempo de espera, taladrado profundo, rotura de viruta o roscado.
tooltip.drill_diameter=Diametro del taladro (solo referencia para la vista previa).
tooltip.drill_depth=Profundidad de taladrado en Z.
tooltip.drill_feed=Avance para el taladrado.
tooltip.drill_safe_z=Posicion Z segura para aproximarse antes del ciclo.
tooltip.drill_dwell=Tiempo de espera en el fondo del taladro (solo ciclo con tiempo de espera).
tooltip.drill_peck_depth=Profundidad de picoteo por golpe en taladrado profundo o rotura de viruta.
tooltip.contour_start_x=Diametro inicial (X) del contorno.
tooltip.contour_start_z=Posicion Z inicial del contorno.
tooltip.contour_coord_mode=Entrada absoluta o incremental de los puntos del contorno.
tooltip.contour_name=Nombre del contorno para vincularlo en pasos de cilindrado/desbaste.
tooltip.contour_add_segment=Anade un nuevo elemento de contorno (fila).
tooltip.contour_delete_segment=Elimina el elemento de contorno seleccionado.
tooltip.contour_move_up=Mueve el elemento de contorno seleccionado hacia arriba.
tooltip.contour_move_down=Mueve el elemento de contorno seleccionado hacia abajo.
tooltip.contour_edge_type=Tratamiento de arista al final de este elemento: ninguno, chaflan o radio.
tooltip.contour_edge_size=Tamano del chaflan o radio en esta arista.
tooltip.contour_arc_side=Posicion del arco para un radio: automatico, exterior o interior.
tooltip.key_mode=Chavetero axial (direccion Z) o frontal (direccion X).
tooltip.key_radial_side=Chavetero en el exterior de un eje o en el interior de un taladro.
tooltip.key_tool=Herramienta usada para el chavetero.
tooltip.key_coolant=Activar refrigerante durante el chaveteado.
tooltip.key_slot_count=Numero de ranuras distribuidas uniformemente en la circunferencia.
tooltip.key_slot_start_angle=Angulo de la primera ranura en el eje C.
tooltip.key_slot_angle_step=Desfase angular entre ranuras consecutivas.
tooltip.key_start_diameter=Diametro en el que comienza la ranura.
tooltip.key_start_z=Posicion Z del inicio de la ranura.
tooltip.key_nut_length=Longitud de la ranura.
tooltip.key_nut_depth=Profundidad de la ranura.
tooltip.key_slot_width=Ancho objetivo de la ranura terminada.
tooltip.key_depth_per_pass=Profundidad de pasada durante el chaveteado.
tooltip.key_plunge_feed=Avance durante la penetracion/chaveteado.
tooltip.key_cutting_width=Ancho de corte de la herramienta; determina el solape en ranuras mas anchas.
tooltip.key_top_clearance=Distancia de seguridad sobre la ranura antes de penetrar.
tooltip.key_use_c_axis=Usar el eje C para el posicionamiento angular de las ranuras.
tooltip.key_use_c_axis_switch=Cambiar a modo eje C mediante codigo M entre ranuras.
tooltip.key_c_axis_switch_p=Parametro P del codigo M usado para cambiar a modo eje C.
