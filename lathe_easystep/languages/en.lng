field.peck_depth=Peck depth
field.depth=Depth
field.width=Width

# --- Ergaenzt: Tooltips fuer Planen/Bohren/Kontur/Keilnut ---
tooltip.face_start_x=Start diameter (X) of the facing cycle.
tooltip.face_start_z=Start Z position of the facing cycle.
tooltip.face_end_x=End diameter (X) of the facing cycle.
tooltip.face_end_z=End Z position of the facing cycle.
tooltip.face_mode=Rough, finish, or both in a single step.
tooltip.face_finish_direction=Finish direction: outside-in or inside-out.
tooltip.face_depth_max=Maximum depth of cut per roughing pass.
tooltip.face_finish_allow_x=Radial finish allowance left after roughing.
tooltip.face_finish_allow_z=Axial finish allowance left after roughing.
tooltip.face_edge_type=Edge treatment at the end of the face: none, chamfer, or radius.
tooltip.face_edge_size=Size of the chamfer or radius on this edge.
tooltip.face_safe_z=Safe Z position to approach before the cycle.
tooltip.face_feed=Feed rate for facing.
tooltip.face_pause_enabled=Brief pause for chip breaking during roughing.
tooltip.face_pause_distance=Travel between two chip-breaking pauses.
tooltip.face_spindle=Spindle speed or cutting speed for this step.
tooltip.face_tool=Tool used for facing.
tooltip.face_coolant=Turn on coolant during facing.
tooltip.face_depth_per_pass=Depth of cut per pass while facing.
tooltip.drill_tool=Tool used for the drilling cycle.
tooltip.drill_spindle=Spindle speed for the drilling cycle.
tooltip.drill_coolant=Turn on coolant during drilling.
tooltip.drill_mode=Drilling cycle type: normal, with dwell, peck drilling, chip breaking, or tapping.
tooltip.drill_diameter=Hole diameter (preview reference only).
tooltip.drill_depth=Drilling depth in Z.
tooltip.drill_feed=Feed rate for drilling.
tooltip.drill_safe_z=Safe Z position to approach before the cycle.
tooltip.drill_dwell=Dwell time at the bottom of the hole (dwell cycle only).
tooltip.drill_peck_depth=Peck depth per stroke for peck drilling or chip breaking.
tooltip.contour_start_x=Start diameter (X) of the contour.
tooltip.contour_start_z=Start Z position of the contour.
tooltip.contour_coord_mode=Absolute or incremental entry of contour points.
tooltip.contour_name=Contour name used to link it in Turning/Roughing steps.
tooltip.contour_add_segment=Adds a new contour element (row).
tooltip.contour_delete_segment=Removes the selected contour element.
tooltip.contour_move_up=Moves the selected contour element up.
tooltip.contour_move_down=Moves the selected contour element down.
tooltip.contour_edge_type=Edge treatment at the end of this contour element: none, chamfer, or radius.
tooltip.contour_edge_size=Size of the chamfer or radius on this edge.
tooltip.contour_arc_side=Placement of the arc for a radius: automatic, outer, or inner.
tooltip.key_mode=Keyway broaching axial (Z direction) or on the face (X direction).
tooltip.key_radial_side=Keyway on the outside of a shaft or inside a bore.
tooltip.key_tool=Tool used for keyway broaching.
tooltip.key_coolant=Turn on coolant during keyway broaching.
tooltip.key_slot_count=Number of slots evenly distributed around the circumference.
tooltip.key_slot_start_angle=Angle of the first slot on the C axis.
tooltip.key_slot_angle_step=Angular offset between consecutive slots.
tooltip.key_start_diameter=Diameter at which the slot begins.
tooltip.key_start_z=Z position of the slot start.
tooltip.key_nut_length=Length of the slot.
tooltip.key_nut_depth=Depth of the slot.
tooltip.key_slot_width=Target width of the finished slot.
tooltip.key_depth_per_pass=Depth of cut per pass while broaching.
tooltip.key_plunge_feed=Feed rate while plunging/broaching.
tooltip.key_cutting_width=Cutter width of the tool; determines overlap for wider slots.
tooltip.key_top_clearance=Safety clearance above the slot before plunging.
tooltip.key_use_c_axis=Use the C axis for angular positioning of the slots.
tooltip.key_use_c_axis_switch=Switch to C-axis mode via M-code between slots.
tooltip.key_c_axis_switch_p=P parameter of the M-code used to switch to C-axis mode.
